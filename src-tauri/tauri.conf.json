{
  "$schema": "https://raw.githubusercontent.com/nicehiro/tauri/dev/tauri-config-schema/schema.json",
  "productName": "chatlog_alpha",
  "version": "0.1.0",
  "identifier": "com.chatlog.alpha",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "chatlog_alpha",
        "width": 1080,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "center": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data: blob: http://127.0.0.1:5030; font-src 'self' data:; connect-src 'self' http://127.0.0.1:5030 http://localhost:5030 ws://127.0.0.1:1421 ws://localhost:1421 https://github.com https://api.github.com; frame-src 'none'; object-src 'none'; base-uri 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": false,
    "windows": {
      "wix": {
        "language": "zh-CN"
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/chatlog_alpha"
    ]
  },
  "plugins": {
    "shell": {
      "open": false
    },
    "updater": {
      "endpoints": [
        "https://github.com/zhoumeng-creater/chatlogUI/releases/latest/download/latest.json"
      ],
      "pubkey": "TAURI_UPDATER_PUBLIC_KEY_INJECTED_BY_RELEASE_WORKFLOW"
    }
  }
}
